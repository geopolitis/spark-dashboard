# Dashboard server
SPARK_DASHBOARD_PORT=8090
SPARK_DASHBOARD_INTERVAL=15
SPARK_DASHBOARD_HISTORY=21600

# Remote hosts over the Spark/IB network
TOULA_REMOTE_HOST=10.10.10.1
KOULA_REMOTE_HOST=10.10.10.2

# Local endpoint view when the dashboard runs on Toula
TOULA_VLLM_URL=http://127.0.0.1:8080
TOULA_PROXY_URL=http://127.0.0.1:8081
KOULA_REMOTE_VLLM_URL=http://10.10.10.2:8080
KOULA_REMOTE_PROXY_URL=http://10.10.10.2:8081

# Local endpoint view when the dashboard runs on Koula
KOULA_VLLM_URL=http://127.0.0.1:8080
KOULA_PROXY_URL=http://127.0.0.1:8081
TOULA_REMOTE_VLLM_URL=http://10.10.10.1:8080
TOULA_REMOTE_PROXY_URL=http://10.10.10.1:8081
